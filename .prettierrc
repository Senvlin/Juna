{
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "vueIndentScriptAndStyle": true,
    "endOfLine": "lf",
    "overrides": [
        {
            "files": [
                "*.vue"
            ],
            "options": {
                "parser": "vue"
            }
        }
    ]
}